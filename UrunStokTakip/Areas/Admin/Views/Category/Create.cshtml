@model Entity.Category

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-6">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Yeni Kategori Ekle</h3>
                    </div>

                    <form asp-action="Create" method="post">
                        <div class="card-body">
                            <div class="form-group">
                                <label for="Name">Kategori Adı</label>
                                <input asp-for="Name" class="form-control" placeholder="Örn: Mutfak Gereçleri">
                            </div>
                            <div class="form-group">
                                <label for="Description">Açıklama</label>
                                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Kategori hakkında kısa bilgi..."></textarea>
                            </div>
                        </div>

                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                            <a asp-action="Index" class="btn btn-default float-right">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}