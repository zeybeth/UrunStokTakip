@model Entity.Category

<div class="card card-info">
    <div class="card-header">
        <h3 class="card-title">Kategoriyi Düzenle: @Model.Name</h3>
    </div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ID" />

        <div class="card-body">
            <div class="form-group">
                <label>Kategori Adı</label>
                <input asp-for="Name" class="form-control" placeholder="Kategori adını giriniz">
            </div>
            <div class="form-group">
                <label>Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-group">
                <div class="custom-control custom-switch">
                    <input asp-for="IsActive" type="checkbox" class="custom-control-input" id="isActiveSwitch">
                    <label class="custom-control-label" for="isActiveSwitch">Kategori Aktif mi?</label>
                </div>
            </div>
        </div>

        <div class="card-footer">
            <button type="submit" class="btn btn-info">Değişiklikleri Kaydet</button>
            <a asp-action="Index" class="btn btn-default float-right">İptal</a>
        </div>
    </form>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}