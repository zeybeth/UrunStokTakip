@model IEnumerable<Entity.Sale>

@{
    ViewData["Title"] = "Sipariş Yönetimi";
}

<section class="content-header">
    <div class="container-fluid">
        <h1>Gelen Siparişler</h1>
    </div>
</section>

<section class="content">
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped m-0">
                <thead class="bg-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Müşteri</th>
                        <th>Ürün</th>
                        <th>Adet</th>
                        <th>Birim Fiyat</th>
                        <th>Toplam</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span class="fw-bold">@item.User?.UserName</span><br />
                                <small class="text-muted">@item.User?.Email</small>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="~/img/@item.Product.Picture" style="width:40px; height:40px; object-fit:cover;" class="rounded me-2" />
                                    <span>@item.Product.Name</span>
                                </div>
                            </td>
                            <td>@item.Quantity</td>
                            <td>@item.Price.ToString("C2")</td>
                            <td class="fw-bold text-primary">@((item.Price * item.Quantity).ToString("C2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>