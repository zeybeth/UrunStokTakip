@model IEnumerable<Entity.Product>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Ürün Listesi</h3>
        <div class="card-tools">
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="fas fa-plus"></i> Yeni Ürün Ekle
            </a>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th style="width: 80px;" class="text-center">Görsel</th>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                    <th style="width: 150px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.Picture))
                            {
                                @* Resim yolunu ~/img/ klasörüne yönlendirdik *@
                                <img src="~/img/@item.Picture" alt="@item.Name"
                                     style="width: 50px; height: 50px; object-fit: cover;"
                                     class="img-thumbnail shadow-sm" />
                            }
                            else
                            {
                                @* Eğer resim yoksa bir ikon veya placeholder gösterelim *@
                                <i class="fas fa-image text-gray fa-2x"></i>
                            }
                        </td>
                        <td>@item.Name</td>
                        <td>@(item.Category != null ? item.Category.Name : "Belirtilmemiş")</td>
                        <td>@item.Price.ToString("C2")</td>
                        <td>@item.Stock</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-info btn-sm">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-danger btn-sm"
                               onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?')">
                                <i class="fas fa-trash"></i> Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>