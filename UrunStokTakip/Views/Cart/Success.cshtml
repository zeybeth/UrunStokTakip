@{
    ViewData["Title"] = "Sipariş Tamamlandı";
}

<div class="container text-center py-5 mt-5" style="min-height: 60vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">

    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 7rem; text-shadow: 0px 4px 10px rgba(25, 135, 84, 0.3);"></i>
    </div>

    <h1 class="display-4 fw-bold text-dark mb-3">Siparişiniz Alındı!</h1>
    <h4 class="text-secondary fw-normal mb-4">Bizi tercih ettiğiniz için teşekkür ederiz.</h4>

    <p class="text-muted w-50 mx-auto fs-5 mb-5">
        Siparişiniz başarıyla sistemimize kaydedildi. Ürünleriniz özenle hazırlanıp en kısa sürede kargoya teslim edilecektir.
    </p>

    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm">
            <i class="bi bi-bag-heart me-2"></i> Alışverişe Devam Et
        </a>
    </div>

</div>