@model int

<li class="nav-item mx-2">
    <a class="nav-link text-dark position-relative d-flex align-items-center" asp-controller="Cart" asp-action="Index">
        <i class="bi bi-cart3" style="font-size: 1.4rem;"></i>
        @if (Model > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size: 0.65rem; padding: 0.35em 0.5em; min-width: 1.5em;">
                @Model
                <span class="visually-hidden">sepet öğeleri</span>
            </span>
        }
    </a>
</li>